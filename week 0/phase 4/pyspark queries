from pyspark.sql import SparkSession
from pyspark.sql import functions as F

# 1. Initialize Spark Session
spark = (
    SparkSession.builder
    .appName("Phase4_Business_Pipeline")
    .getOrCreate()
)

# 2. Load Data
customers = (
    spark.read.format("csv")
    .option("header", "true")
    .option("inferSchema", "true")
    .load("/samples/customers.csv")
)

sales = (
    spark.read.format("csv")
    .option("header", "true")
    .option("inferSchema", "true")
    .load("/samples/sales.csv")
)

# 3. Data Cleaning
customers = (
    customers
    .dropna(subset=["customer_id"])
    .dropDuplicates(["customer_id"])
)

sales = (
    sales
    .dropna(subset=["customer_id"])
    .dropDuplicates(["sale_id"])
    .filter(F.col("total_amount") > 0)
)

# Task 1: Daily Sales
daily_sales = (
    sales.groupBy("sale_date")
    .agg(F.sum("total_amount").alias("total_sales"))
)
daily_sales.show()

# Task 2: City Revenue
city_revenue = (
    sales.join(customers, "customer_id")
    .groupBy("city")
    .agg(F.sum("total_amount").alias("total_revenue"))
)
city_revenue.show()

# Task 3: Top Customers
customers = customers.withColumn(
    "customer_name",
    F.concat_ws(" ", F.col("first_name"), F.col("last_name"))
)

top_customers = (
    sales.join(customers, "customer_id")
    .groupBy("customer_name")
    .agg(F.sum("total_amount").alias("total_spend"))
    .orderBy(F.desc("total_spend"))
    .limit(5)
)
top_customers.show()

# Task 4: Repeat Customers
repeat_customers = (
    sales.groupBy("customer_id")
    .agg(F.count("sale_id").alias("order_count"))
    .filter(F.col("order_count") > 1)
)
repeat_customers.show()

# Task 5: Customer Segmentation
customer_spend = (
    sales.groupBy("customer_id")
    .agg(F.sum("total_amount").alias("total_spend"))
)

segmentation = (
    customer_spend.join(customers, "customer_id")
    .withColumn(
        "segment",
        F.when(F.col("total_spend") > 1000, "Gold")
        .when(
            (F.col("total_spend") >= 50) & (F.col("total_spend") <= 100),
            "Silver"
        )
        .otherwise("Bronze")
    )
)
segmentation.show()

# Task 6: Final Output
final_df = (
    segmentation.join(repeat_customers, "customer_id", "left")
    .fillna({"order_count": 1})
    .select("customer_name", "city", "total_spend", "order_count", "segment")
)
final_df.show()

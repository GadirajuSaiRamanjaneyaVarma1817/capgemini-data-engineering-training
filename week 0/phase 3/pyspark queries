from pyspark.sql import SparkSession
from pyspark.sql.functions import col, sum as total_sum

spark = SparkSession.builder.appName("Sales Analysis").getOrCreate()

cust_df = spark.read.format("csv").option("header", "true").option("inferSchema", "true").load("/samples/customers.csv")
sales_df = spark.read.format("csv").option("header", "true").option("inferSchema", "true").load("/samples/sales.csv")

sales_df = sales_df.withColumn("total_amount", col("total_amount").cast("double"))

joined_df = cust_df.join(sales_df, on="customer_id")

result_df = joined_df.groupBy("city") \
    .agg(total_sum("total_amount").alias("total_revenue"))

result_df.show()


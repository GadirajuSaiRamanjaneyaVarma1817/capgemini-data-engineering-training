from pyspark.sql import SparkSession
from pyspark.sql.functions import col, sum, concat_ws

spark = SparkSession.builder.appName('Spark Playground').getOrCreate()
customers = spark.read.format('csv').option('header', 'true').option('inferSchema', 'true').load('/samples/customers.csv')
sales = spark.read.format('csv').option('header', 'true').option('inferSchema', 'true').load('/samples/sales.csv')
sales_clean = sales.withColumn("total_amount", col("total_amount").cast("double"))

customer_totals = customers.join(sales_clean, "customer_id") \
    .withColumn("cus_name", concat_ws(" ", col("first_name"), col("last_name"))) \
    .groupBy("cus_name", "city") \
    .agg(sum("total_amount").alias("amount"))

customer_totals.show()

